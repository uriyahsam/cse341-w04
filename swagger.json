{
  "openapi": "3.0.0",
  "info": {
    "title": "CSE341 Library API",
    "description": "REST API for Books and Authors. POST, PUT, DELETE require GitHub OAuth login.\n\n**To authenticate:**\n1. Open a new browser tab → navigate to `GET /auth/github` on your Render URL\n2. Authorize with GitHub → you will be redirected back logged in\n3. Return to `/api-docs` — protected routes now work for your session",
    "version": "2.0.0",
    "contact": { "name": "Uriyah Sam" }
  },
  "servers": [
    { "url": "https://cse341-w04.onrender.com", "description": "Production (Render)" },
    { "url": "http://localhost:3000", "description": "Local" }
  ],
  "tags": [
    { "name": "Auth",    "description": "GitHub OAuth — login, logout, status" },
    { "name": "Books",   "description": "GET is public. POST / PUT / DELETE require login 🔒" },
    { "name": "Authors", "description": "GET is public. POST / PUT / DELETE require login 🔒" }
  ],
  "paths": {
    "/auth/github": {
      "get": {
        "summary": "Initiate GitHub OAuth login",
        "description": "**Paste this URL into a browser tab** — do not use Swagger Try-It-Out here. GitHub will ask you to authorize. After approval you are redirected back and logged in.",
        "tags": ["Auth"],
        "responses": { "302": { "description": "Redirects to GitHub authorization page" } }
      }
    },
    "/auth/github/callback": {
      "get": {
        "summary": "GitHub OAuth callback (automatic)",
        "description": "GitHub calls this automatically. Do not call manually.",
        "tags": ["Auth"],
        "responses": {
          "200": { "description": "Login successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginSuccess" } } } },
          "302": { "description": "Redirects to /api-docs on failure" }
        }
      }
    },
    "/auth/status": {
      "get": {
        "summary": "Check current login status",
        "tags": ["Auth"],
        "responses": { "200": { "description": "Auth status", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthStatus" } } } } }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Log out and destroy session",
        "tags": ["Auth"],
        "responses": { "200": { "description": "Logged out", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Logged out successfully." } } } } } } }
      }
    },
    "/books": {
      "get": {
        "summary": "Get all books (public)",
        "tags": ["Books"],
        "responses": {
          "200": { "description": "Array of books", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Book" } } } } },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "post": {
        "summary": "🔒 Create a book (login required)",
        "description": "Requires GitHub OAuth session. Log in via GET /auth/github first.",
        "tags": ["Books"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BookInput" },
            "example": { "title": "Things Fall Apart", "author": "Chinua Achebe", "genre": "Literary Fiction", "publishedYear": 1958, "isbn": "9780385474542", "language": "English", "pageCount": 209, "availableCopies": 5, "synopsis": "A story about pre-colonial life in Nigeria." } } }
        },
        "responses": {
          "201": { "description": "Created — returns new ID", "content": { "application/json": { "schema": { "type": "object", "properties": { "id": { "type": "string" } } } } } },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/books/{id}": {
      "get": {
        "summary": "Get a book by ID (public)",
        "tags": ["Books"],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": { "description": "The book", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Book" } } } },
          "400": { "$ref": "#/components/responses/InvalidId" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "put": {
        "summary": "🔒 Update a book (login required)",
        "tags": ["Books"],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BookInput" },
            "example": { "title": "Things Fall Apart", "author": "Chinua Achebe", "genre": "Literary Fiction", "publishedYear": 1958, "isbn": "9780385474542", "language": "English", "pageCount": 209, "availableCopies": 3, "synopsis": "Updated." } } }
        },
        "responses": {
          "204": { "description": "Updated (no content)" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "delete": {
        "summary": "🔒 Delete a book (login required)",
        "tags": ["Books"],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": { "description": "Deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Book deleted successfully." } } } } } },
          "400": { "$ref": "#/components/responses/InvalidId" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/authors": {
      "get": {
        "summary": "Get all authors (public)",
        "tags": ["Authors"],
        "responses": {
          "200": { "description": "Array of authors", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Author" } } } } },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "post": {
        "summary": "🔒 Create an author (login required)",
        "tags": ["Authors"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthorInput" },
            "example": { "firstName": "Chinua", "lastName": "Achebe", "nationality": "Nigerian", "birthYear": 1930, "genre": "Literary Fiction", "email": "chinua@example.com", "booksPublished": 21, "biography": "Nigerian novelist." } } }
        },
        "responses": {
          "201": { "description": "Created — returns new ID", "content": { "application/json": { "schema": { "type": "object", "properties": { "id": { "type": "string" } } } } } },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/authors/{id}": {
      "get": {
        "summary": "Get an author by ID (public)",
        "tags": ["Authors"],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": { "description": "The author", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Author" } } } },
          "400": { "$ref": "#/components/responses/InvalidId" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "put": {
        "summary": "🔒 Update an author (login required)",
        "tags": ["Authors"],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthorInput" },
            "example": { "firstName": "Chinua", "lastName": "Achebe", "nationality": "Nigerian", "birthYear": 1930, "genre": "Literary Fiction", "email": "updated@example.com", "booksPublished": 22, "biography": "Updated." } } }
        },
        "responses": {
          "204": { "description": "Updated (no content)" },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "delete": {
        "summary": "🔒 Delete an author (login required)",
        "tags": ["Authors"],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": { "description": "Deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Author deleted successfully." } } } } } },
          "400": { "$ref": "#/components/responses/InvalidId" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "id": {
        "name": "id", "in": "path", "required": true,
        "description": "MongoDB ObjectId (24-char hex)",
        "schema": { "type": "string", "example": "64abc123def456789012345" }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Not logged in — visit GET /auth/github in browser first",
        "content": { "application/json": { "schema": { "type": "object", "properties": { "error": { "type": "string", "example": "Unauthorized. Please log in first: visit GET /auth/github in your browser." } } } } }
      },
      "ValidationError": {
        "description": "Validation failed",
        "content": { "application/json": { "schema": { "type": "object", "properties": { "error": { "type": "string", "example": "Validation failed." }, "details": { "type": "array", "items": { "type": "string" }, "example": ["\"title\" is required."] } } } } }
      },
      "InvalidId": {
        "description": "Invalid MongoDB ObjectId",
        "content": { "application/json": { "schema": { "type": "object", "properties": { "error": { "type": "string", "example": "Invalid ID format. Must be a 24-character hex string." } } } } }
      },
      "NotFound": {
        "description": "Not found",
        "content": { "application/json": { "schema": { "type": "object", "properties": { "error": { "type": "string", "example": "No book found with id: 64abc123def456789012345" } } } } }
      },
      "ServerError": {
        "description": "Internal server error",
        "content": { "application/json": { "schema": { "type": "object", "properties": { "error": { "type": "string" }, "details": { "type": "string" } } } } }
      }
    },
    "schemas": {
      "LoginSuccess": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "Login successful." },
          "user": { "type": "object", "properties": {
            "id": { "type": "string" }, "displayName": { "type": "string", "example": "Uriyah Sam" },
            "username": { "type": "string", "example": "uriyahsam" }, "profileUrl": { "type": "string" }
          }}
        }
      },
      "AuthStatus": {
        "type": "object",
        "properties": {
          "loggedIn": { "type": "boolean", "example": true },
          "user": { "type": "object", "properties": {
            "id": { "type": "string" }, "displayName": { "type": "string" }, "username": { "type": "string" }
          }}
        }
      },
      "Book": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" }, "title": { "type": "string", "example": "Things Fall Apart" },
          "author": { "type": "string", "example": "Chinua Achebe" }, "genre": { "type": "string", "example": "Literary Fiction" },
          "publishedYear": { "type": "integer", "example": 1958 }, "isbn": { "type": "string", "example": "9780385474542" },
          "language": { "type": "string", "example": "English" }, "pageCount": { "type": "integer", "example": 209 },
          "availableCopies": { "type": "integer", "example": 5 }, "synopsis": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "BookInput": {
        "type": "object",
        "required": ["title","author","genre","publishedYear","isbn","language","pageCount","availableCopies"],
        "properties": {
          "title": { "type": "string" }, "author": { "type": "string" }, "genre": { "type": "string" },
          "publishedYear": { "type": "integer", "example": 1958 }, "isbn": { "type": "string", "description": "10 or 13 digit ISBN" },
          "language": { "type": "string" }, "pageCount": { "type": "integer", "minimum": 1 },
          "availableCopies": { "type": "integer", "minimum": 0 }, "synopsis": { "type": "string" }
        }
      },
      "Author": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" }, "firstName": { "type": "string" }, "lastName": { "type": "string" },
          "nationality": { "type": "string" }, "birthYear": { "type": "integer" }, "genre": { "type": "string" },
          "email": { "type": "string", "format": "email" }, "booksPublished": { "type": "integer" },
          "biography": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "AuthorInput": {
        "type": "object",
        "required": ["firstName","lastName","nationality","birthYear","genre","email","booksPublished"],
        "properties": {
          "firstName": { "type": "string" }, "lastName": { "type": "string" },
          "nationality": { "type": "string" }, "birthYear": { "type": "integer" },
          "genre": { "type": "string" }, "email": { "type": "string", "format": "email" },
          "booksPublished": { "type": "integer", "minimum": 0 }, "biography": { "type": "string" }
        }
      }
    }
  }
}
